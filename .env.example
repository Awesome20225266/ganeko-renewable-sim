# ============================================================================
# Renewable Generation Simulation Platform — environment configuration
# Copy this file to `.env` and adjust. Nothing is hardcoded in the source.
# ============================================================================

# ---- Database --------------------------------------------------------------
# SQLite (zero-config local default). Use the Postgres URL when running docker.
DATABASE_URL=sqlite:///./data/renewable.db
# Example Postgres (docker-compose sets this automatically for the api/scheduler):
# DATABASE_URL=postgresql+psycopg2://renew:renew@db:5432/renewable

# ---- Admin bootstrap -------------------------------------------------------
# On `seed`, an admin API key is created. If this is set, that exact key is used
# (idempotent); otherwise a random key is generated and printed once.
ADMIN_BOOTSTRAP_KEY=admin-dev-key-change-me
# Team/owner label attached to the bootstrap admin key.
ADMIN_KEY_TEAM=platform-admin

# ---- Seed plant location (CONFIGURABLE PLACEHOLDER — not baked into code) ---
# Defaults to the real site (Ganeko Two Energy Private Limited, Karnataka, India).
# Change freely; lat is +N, lon is +E.
PLANT_CODE=HYBRID01
PLANT_NAME=Ganeko Two Energy Private Limited
PLANT_LAT=17.60
PLANT_LON=76.36
PLANT_TZ=Asia/Kolkata

# ---- Open-Meteo base URLs (no API key required for non-commercial use) ------
OPEN_METEO_FORECAST_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_HISTORICAL_FORECAST_URL=https://historical-forecast-api.open-meteo.com/v1/forecast
OPEN_METEO_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive
OPEN_METEO_TIMEOUT_SECONDS=30
OPEN_METEO_MAX_RETRIES=4

# ---- Scheduler -------------------------------------------------------------
# Enable the in-process daily scheduler (set false to disable, e.g. for tests).
SCHEDULER_ENABLED=true
# Daily run time in the plant's local timezone (24h HH:MM).
SCHEDULER_DAILY_TIME=00:30
# How often the "live" refresh job runs during the day (minutes).
LIVE_REFRESH_MINUTES=15

# ---- Dashboard -------------------------------------------------------------
DASHBOARD_REFRESH_SECONDS=900
# The dashboard console edits config / generates keys / runs simulations WITHOUT an
# API key (trusted same-origin admin console). Keep true for local/trusted networks.
# Set false in production to disable those write actions (read-only feeds stay on);
# consumers then use the key-protected /plants & /admin APIs.
DASHBOARD_CONSOLE_WRITE=true

# ---- API / security --------------------------------------------------------
# Default per-key rate limit (requests per minute) when a key has none set.
DEFAULT_RATE_LIMIT_PER_MIN=120
API_KEY_HEADER=X-API-Key
# Comma-separated allowed CORS origins so other front-ends can fetch the API.
# Use "*" for local dev; restrict to your dashboard origin(s) in production.
CORS_ALLOW_ORIGINS=*

# ---- Restricted user-facing wrapper API (/api/renewable/*) -----------------
# A locked-down API that exposes ONLY live + historical data (never forecast).
# It reads this app's own data in-process — no provider key or outbound call.
RENEWABLE_PLANT_ID=HYBRID01
# Plant timezone — used to compute "today" so same-day requests aren't rejected.
RENEWABLE_PLANT_TZ=Asia/Kolkata
# Optional shared key external users/Excel must send as X-API-Key. Blank = open.
# Set this to one value you hand to your users before sharing the wrapper.
RENEWABLE_WRAPPER_USER_API_KEY=

# ---- App -------------------------------------------------------------------
LOG_LEVEL=INFO
SIMULATION_VERSION=v1.0.0
MODEL_ASSUMPTION_VERSION=v1.0.0
# Adds realistic block-to-block variability (cloud-driven solar flicker, wind
# turbulence) so output resembles real metered data. Deterministic + bounded.
# Set false for perfectly smooth, purely physics-driven curves.
REALISM_TEXTURE=true
